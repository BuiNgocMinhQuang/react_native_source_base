{
  "name": "MyApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "openSimulator": "open -a Simulator",
    "reset": "react-native start --reset-cache",
    "link": "npx react-native-asset",
    "kill-metro": "(lsof -t -i:8081 | xargs kill -9) || (lsof -t -i:8080 | xargs kill -9) || true",
    "kill-android": "adb uninstall com.thuanviet_resident.dev || true",
    "start-fresh": "yarn kill-metro && yarn kill-android && yarn reset",
    "start_dev": "yarn kill-metro && ENVFILE=.env.dev react-native start --port 8081",
    "setup-new-arch": "node scripts/setupNewArch.js",
    "env:dev": "./switch-env.sh dev",
    "env:prod": "./switch-env.sh prod",
    "env:auto": "./switch-env.sh auto",
    "ios_dev": "ENVFILE=.env.dev react-native run-ios --scheme thuanviet_resident",
    "ios_pro": "ENVFILE=.env.production react-native run-ios --scheme thuanviet_resident_pro --mode Release",
    "ios_pro_debug": "ENVFILE=.env.production react-native run-ios --scheme thuanviet_resident_pro",
    "ios_dev_setup": "cd ios && ./setup_development_env.sh",
    "ios_pro_setup": "cd ios && ./setup_production_env.sh",
    "android_dev": "adb reverse tcp:8081 tcp:8081 && adb uninstall com.thuanviet_resident.dev || true && cd android && ./gradlew clean && cd .. && ENVFILE=.env.dev react-native run-android --mode=devDebug",
    "android_pro": "adb uninstall com.thuanviet.resident || true && cd android && ./gradlew clean && cd .. && ENVFILE=.env.production react-native run-android --mode=proDebug",
    "android_dev_release": "ENVFILE=.env.dev react-native run-android --mode=devRelease",
    "android_pro_release": "ENVFILE=.env.production react-native run-android --mode=proRelease",
    "android_dev_fresh": "yarn kill-metro && yarn kill-android && yarn android_dev",
    "android_dev_setup": "yarn setup-new-arch && yarn android_dev",
    "android_dev_full": "yarn start_dev & sleep 5 && yarn android_dev",
    "build-android-dev-apk": "./scripts/auto-build-deploy.sh --platform android --env dev --format apk",
    "build-android-dev-apk-firebase": "./scripts/auto-build-deploy.sh --platform android --env dev --format apk --firebase-deploy",
    "build-android-dev-aab": "./scripts/auto-build-deploy.sh --platform android --env dev --format aab",
    "build-android-prod-apk": "./scripts/auto-build-deploy.sh --platform android --env prod --format apk",
    "build-android-prod-aab": "./scripts/auto-build-deploy.sh --platform android --env prod --format aab",
    "build-ios-dev-archive": "./scripts/auto-build-deploy.sh --platform ios --env dev --format archive",
    "build-ios-dev-ipa": "./scripts/auto-build-deploy.sh --platform ios --env dev --format ipa",
    "build-ios-prod-archive": "./scripts/auto-build-deploy.sh --platform ios --env prod --format archive",
    "build-ios-prod-ipa": "./scripts/auto-build-deploy.sh --platform ios --env prod --format ipa"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "axios": "^1.13.6",
    "i18next": "^25.8.18",
    "react": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.8",
    "react-native": "0.84.1",
    "react-native-config": "^1.6.1",
    "react-native-localize": "^3.7.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
